// 弓道部：正規練習の的中記録（〇×）用スキーマ

generator client {
  provider      = "prisma-client-js"
  // Vercel（Linux）上のクエリエンジンを確実に含める（ローカル開発は native のまま）
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// Supabase + Vercel: ランタイムは Transaction pooler（DATABASE_URL）、マイグレーションは DIRECT_URL
// 直結1本だけの環境では両方に同じ URI を設定すればよい
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Member {
  id         String   @id @default(cuid())
  name       String
  gradeYear  String   @default("") // 1年〜4年（プルダウン）
  gender     String   @default("") // 男 / 女
  role       String   @default("") // 役職（プルダウン）
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  records    RoundRecord[]
}

model PracticeSession {
  id         String   @id @default(cuid())
  practiceDate String // YYYY-MM-DD（タイムゾーンずれ防止のため文字列で保持）
  memo       String   @default("")
  sessionKind String @default("joint") // joint=正規練習, match=試合
  roundCount Int      @default(5)
  // 参加対象: all=男女合同, 男=男子のみ, 女=女子のみ
  genderScope     String   @default("all")
  // attendanceJson: memberId -> present|absent|late|early|partial（未記載は参加）
  attendanceJson  String   @default("{}")
  // absentReasonsJson: memberId -> 理由（attendance が absent/late/early/partial の人だけ）
  absentReasonsJson String @default("{}")
  // lineupTeamsJson: チーム配列。[] のときは出席者を学年順で並べる
  lineupTeamsJson String   @default("[]")
  // lineupTeamSizesJson: チーム順の人数設定配列
  lineupTeamSizesJson String @default("[]")
  // lineupTeamInfoJson: チーム順の情報ラベル配列（未選択は ""）
  lineupTeamInfoJson String @default("[]")
  // substitutionsJson: [{ roundIndex, outMemberId, inMemberId }]。指定立目以降の交代
  substitutionsJson String @default("[]")
  teamSize        Int      @default(4)
  maxMato         Int      @default(8)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  records    RoundRecord[]
}

// 1立ち＝4射。marks は DB 上で o=的中, x=外し の4文字（例: ooxx）
model RoundRecord {
  id         String   @id @default(cuid())
  sessionId  String
  memberId   String
  roundIndex Int
  marks      String

  session PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member  Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId, roundIndex])
}
